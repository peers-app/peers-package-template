{
  "name": "peers-package-template",
  "version": "0.1.0",
  "repository": "https://github.com/peers-app/peers-package-template.git",
  "author": "<package-author>",
  "license": "MIT",
  "peers": {
    "packageId": "<package-id>"
  },
  "scripts": {
    "build:package": "webpack --mode production --no-watch --config webpack.package.config.js",
    "build:routes": "webpack --mode production --no-watch --config webpack.routes.config.js",
    "build:uis": "webpack --mode production --no-watch --config webpack.uis.config.js",
    "build": "npm run build:package && npm run build:routes && npm run build:uis",
    "dev:package": "webpack --mode development --watch --config webpack.package.config.js",
    "dev:routes": "webpack --mode development --watch --config webpack.routes.config.js",
    "dev:uis": "webpack --mode development --watch --config webpack.uis.config.js",
    "dev": "concurrently \"npm run dev:package\" \"npm run dev:routes\" \"npm run dev:uis\"",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "peerDependencies": {
    "@peers-app/peers-sdk": "*",
    "react": "18.3.1"
  },
  "dependencies": {
    "lodash": "^4.17.21"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.11",
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@types/lodash": "^4.14.195",
    "@types/node": "^22.4.0",
    "@types/react": "18.3.1",
    "babel-loader": "^9.1.3",
    "concurrently": "^9.1.0",
    "css-loader": "^7.1.2",
    "@peers-app/peers-sdk": "latest",
    "source-map-loader": "^5.0.0",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^5.8.3",
    "webpack": "^5.97.1",
    "webpack-cli": "^5.1.4",
    "zod": "3.25.76"
  }
}
